rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Global Safety Net (allow public operations since anyone can register, fill forms, and save data)
    match /{document=**} {
      allow read, write: if true;
    }

    // Site Settings: Allow public read/write
    match /siteSettings/{configId} {
      allow read, write: if true;
    }

    // Students: Allow public read/write
    match /students/{studentId} {
      allow read, write: if true;
    }

    // Alumni: Allow public read/write
    match /alumni/{alumniId} {
      allow read, write: if true;
    }

    // Registrations: Allow public read/write
    match /registrations/{registrationId} {
      allow read, write: if true;
    }

    // Payments: Allow public read/write
    match /payments/{paymentId} {
      allow read, write: if true;
    }

    // Results: Allow public read/write
    match /results/{resultId} {
      allow read, write: if true;
    }

    // Sessions: Allow public read/write
    match /sessions/{sessionId} {
      allow read, write: if true;
    }
  }
}
